# Backend API
VITE_API_BASE=http://localhost:3000/api

# MapTiler — required for the MapLibre styles.
# This is a publishable client-side key; restrict it by allowed origin in the
# MapTiler dashboard (Account → Keys) so a visible key cannot be abused.
VITE_MAPTILER_KEY=your-maptiler-key

# Default language
VITE_DEFAULT_LANG=sv