# Don't redirect these files - serve them directly
/robots.txt   /robots.txt   200

# Proxy the API through Netlify (topology A) so the browser only ever talks to
# this origin — the backend session cookie stays first-party to badaweb.netlify.app
# and CORS drops out. Must precede the catch-all.
/api/*   https://bada-backend.vercel.app/api/:splat   200

# Catch-all: serve index.html for client-side routing
/*   /index.html   200