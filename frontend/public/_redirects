# Don't redirect these files - serve them directly
/robots.txt   /robots.txt   200

# Unsigned /api proxy fallback (restores routing while we get the signed
# netlify.toml rule working). Must precede the catch-all.
/api/*   https://bada-backend.vercel.app/api/:splat   200

# Catch-all: serve index.html for client-side routing
/*   /index.html   200